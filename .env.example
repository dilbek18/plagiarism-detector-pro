# Render > Environment ichiga qo'yiladi. Frontendga yoki GitHubga maxfiy kalitlarni yozmang.
PYTHON_VERSION=3.11.9
WEB_CONCURRENCY=1
PYTHONUNBUFFERED=1
PIP_NO_CACHE_DIR=1

# Google Programmable Search JSON API
GOOGLE_API_KEY=your_google_api_key
GOOGLE_CSE_ID=your_google_programmable_search_engine_id_cx

# Optional search engines
BRAVE_API_KEY=your_brave_search_api_key
SERPER_API_KEY=your_serper_api_key
SEARCHAPI_API_KEY=your_searchapi_key_for_duckduckgo

# Free Render uchun cheklovlar
MAX_TEXT_CHARS=25000
MAX_FETCH_BYTES=650000
REQUEST_TIMEOUT=12
